{
  "info": {
    "_postman_id": "invoice-payment-service-collection",
    "name": "Invoice & Payment Service",
    "description": "Invoice & Payment Service \u2014 single file (no separate environment).\n\nSETUP:\n1. docker compose up --build\n2. Collection \u2192 Variables tab \u2192 set apiKey = BUSINESS API KEY from logs\n3. Run folder 00 then 01 in order\n\nVariables in this collection: baseUrl, pspBaseUrl, apiKey, customerApiKey, customerId, invoiceId, webhookUrl",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{apiKey}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "pspBaseUrl",
      "value": "http://localhost:9090",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "",
      "type": "string",
      "description": "Required: BUSINESS API KEY from docker logs (not customer key). Example: sk_50c227a909f58d1635aab180943f7bc3"
    },
    {
      "key": "customerApiKey",
      "value": "",
      "type": "string"
    },
    {
      "key": "customerId",
      "value": "",
      "type": "string"
    },
    {
      "key": "invoiceId",
      "value": "",
      "type": "string"
    },
    {
      "key": "webhookUrl",
      "value": "https://webhook.site/your-unique-id",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "00 - Setup & Health",
      "item": [
        {
          "name": "SETUP - Edit Collection Variables",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "health"
              ]
            },
            "description": "No separate environment file.\n\n1. Click collection name \u2192 Variables tab\n2. Set apiKey from: docker logs invoice-service-api-1 | grep BUSINESS API KEY\n3. Run Health Check then 01 - Happy Path"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API up', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create API Key (rotate)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api-keys",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api-keys"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('has authorization', () => pm.expect(j.authorization).to.match(/^Bearer sk_/));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List API Keys",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api-keys",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api-keys"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "01 - Happy Path (run in order)",
      "item": [
        {
          "name": "Create Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('customerId', j.id);",
                  "if (j.api_key) {",
                  "  pm.collectionVariables.set('customerApiKey', j.api_key);",
                  "  console.log('Customer Bearer:', j.authorization);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Smith\",\n  \"email\": \"alice@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/customers",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "customers"
              ]
            }
          }
        },
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/customers",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "customers"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Customer",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/customers/{{customerId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "customers",
                "{{customerId}}"
              ]
            }
          }
        },
        {
          "name": "Create Invoice (draft)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('state draft', () => pm.expect(j.state).to.eql('draft'));",
                  "pm.collectionVariables.set('invoiceId', j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"{{customerId}}\",\n  \"due_date\": \"2025-12-31\",\n  \"line_items\": [\n    { \"description\": \"Widget A\", \"quantity\": 2, \"unit_amount_cents\": 1500 },\n    { \"description\": \"Widget B\", \"quantity\": 1, \"unit_amount_cents\": 500 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/invoices",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "invoices"
              ]
            }
          }
        },
        {
          "name": "Finalize Invoice (draft \u2192 open)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('state open', () => pm.expect(pm.response.json().state).to.eql('open'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}/finalize",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "invoices",
                "{{invoiceId}}",
                "finalize"
              ]
            }
          }
        },
        {
          "name": "Pay Invoice - Success (tok_success)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set('idempotencyKey', 'pay-success-' + Date.now());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('succeeded', () => pm.expect(pm.response.json().status).to.eql('succeeded'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_token\": \"tok_success\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}/pay",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "invoices",
                "{{invoiceId}}",
                "pay"
              ]
            }
          }
        },
        {
          "name": "Get Invoice (should be paid)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('state paid', () => pm.expect(pm.response.json().state).to.eql('paid'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "invoices",
                "{{invoiceId}}"
              ]
            }
          }
        }
      ]
    },
