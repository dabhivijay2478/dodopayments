# Copy to .env for local runs: cp .env.example .env
# API and tests both use DATABASE_URL from here (or from the shell / docker-compose).
# Postgres is exposed on host port 5433 (see docker-compose.yml).

DATABASE_URL=postgres://postgres:postgres@localhost:5433/invoicedb?sslmode=disable
PORT=8080
PSP_BASE_URL=http://localhost:9090
SEED_DATA=true
